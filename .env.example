# ═══════════════════════════════════════════════════════
# AquaVision Analytics — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# App
APP_NAME=AquaVision Analytics
DEBUG=false
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_SECRET_KEY=your-jwt-secret-here-generate-with-openssl-rand-hex-32

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Database (auto-configured via docker-compose, change for production)
DATABASE_URL=postgresql+asyncpg://aquavision:aquavision@db:5432/aquavision
DATABASE_SYNC_URL=postgresql://aquavision:aquavision@db:5432/aquavision

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# MinIO / S3 Storage
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# AI — Anthropic Claude (required for CoachAssist)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Live Streaming
RTMP_SERVER_URL=rtmp://mediamtx:1935

# AI Model (optional — will use base YOLOv8 if not provided)
YOLO_MODEL_PATH=ml/models/waterpolo_yolo.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# Stripe (optional — for subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CDN (optional — for production media delivery)
CDN_BASE_URL=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
